# ─────────────────────────────────────────────────────────────────────────────
# Instantly Live Dashboard — environment configuration
#
# The app runs out-of-the-box with MOCK data when nothing here is set.
# Fill these in to switch to real Instantly + Supabase data.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (server-side). Used to store metric snapshots (history/trends) and
# client feedback. Without it, the app keeps working but feedback/history are
# kept in-memory only (lost on restart).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Fallback single-tenant Instantly API key (V2).
# Used for the "demo" client and as a default when a client has no key in DB.
# Get it from Instantly → Settings → Integrations → API Keys (V2).
INSTANTLY_API_KEY=

# Optional: protect the /api/sync cron endpoint with a shared secret.
# Vercel Cron will send `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# ── Alerting (P0.1 · notify.ts, Telegram) ────────────────────────────────────
# The 07:00 automations cron pushes vital alerts (account 550s / negative
# status, open-rate collapse) to a Telegram chat. WITHOUT these two vars notify()
# is a no-op (logs and skips) — safe to deploy before secrets are set.
# TELEGRAM_CHAT_ID is the recipient and can be re-pointed WITHOUT a deploy.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Campaign Manager Agent (tab "Agent") ─────────────────────────────────────
# Claude key used to generate/review reply drafts. WITHOUT it the agent degrades
# to template drafts (never crashes). Get it from console.anthropic.com.
ANTHROPIC_API_KEY=
# Optional: override the model (default: claude-sonnet-5).
AGENT_MODEL=
# Optional: max reply drafts per GET /agent load (default: 8; use ?email= for one).
AGENT_DRAFT_CAP=

# Optional: comma-separated client definitions for quick setup WITHOUT Supabase.
# Format: slug|Display Name|instantly_api_key  (one client per entry)
# Example: acme|ACME Corp|inst_xxx,globex|Globex|inst_yyy
DASHBOARD_CLIENTS=
